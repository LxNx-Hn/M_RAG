# ── 필수 설정 ──────────────────────────────────────────────────────────────────

# GT 생성에 GPT-4o 사용 (STEP 5). 없으면 로컬 Naive RAG fallback으로 GT 생성.
# 논문 실험에는 설정을 강력히 권장 (독립적 GT 확보를 위해).
OPENAI_API_KEY=

# ── 생성 모델 ──────────────────────────────────────────────────────────────────

# 논문 기준 실험 모델 (Base)
GENERATION_MODEL=K-intelligence/Midm-2.0-Base-Instruct

# 로컬 스모크 검증 시 Mini 모델로 전환 가능 (주석 해제 후 사용)
# GENERATION_MODEL=K-intelligence/Midm-2.0-Mini-Instruct

# ── API 서버 ──────────────────────────────────────────────────────────────────

# 비워두면 master_run.py 가 실행 시 ephemeral 키를 자동 생성
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# GPU 모델 로드 여부 (false 로 설정하면 검색만 가능한 경량 모드)
LOAD_GPU_MODELS=true

# ── 데이터베이스 ──────────────────────────────────────────────────────────────

# Alice Cloud / 로컬 실험: SQLite (별도 설치 불필요)
DATABASE_URL=sqlite+aiosqlite:///./mrag.db

# 운영 배포: PostgreSQL (아래 주석 해제 후 사용)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mrag
